# نسخ هذا الملف إلى .env واملأ القيم. لا ترفع ملف .env إلى Git.
#
# تنبيه (Vite): المتغيرات ذات البادئة VITE_ تُدمَج في الواجهة عند البناء.
# للإنتاج يُفضّل استدعاء نموذج عبر وكيل خادمي لإخفاء المفاتيح تماماً.

# xAI — Grok (تحيات وأسئلة عامة وبسيطة)
VITE_XAI_API_KEY=
VITE_XAI_MODEL=grok-2-latest

# OpenAI — أسئلة محاسبية متخصصة أو تحليل معقد
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
