# اتصال PostgreSQL (على STC أو محلي)
DATABASE_URL=postgresql://wadaq:YOUR_PASSWORD@127.0.0.1:5432/wadaq

# توقيع JWT — استخدم قيمة عشوائية طويلة في الإنتاج
JWT_SECRET=change_me_to_random_64_chars_minimum

# نفس معرف عميل Google في الواجهة (VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# أصول مسموح بها لـ CORS (مفصولة بفواصل)، أو * للتجربة فقط
CORS_ORIGINS=http://localhost:5173,https://rikazai.com,https://www.rikazai.com

PORT=8787
